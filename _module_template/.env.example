# Variables de entorno para [Module Name]
# Copie este archivo a .env y configure los valores según sea necesario.

# Ejemplo: Conexión a la base de datos (si el módulo usa una BD dedicada o esquema)
# MODULE_DATABASE_URL="postgresql://module_user:module_pass@aletheia_db_host:5432/module_db_name"

# Ejemplo: Clave API para un servicio externo
# MODULE_EXTERNAL_API_KEY="YOUR_API_KEY_HERE"

# Ejemplo: Configuración específica del módulo
# MODULE_FEATURE_FLAG_X="true"
# MODULE_PROCESSING_BATCH_SIZE="100"

# Puerto para la API del módulo (si es un servicio)
# MODULE_API_PORT="800X" # Asegurarse de que no colisione con otros servicios

# Configuración de Logging
# LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Si se conecta a servicios compartidos de Aletheia (ej. MLflow, Redis)
# y no se gestionan por un docker-compose.yml principal que inyecte las URLs,
# podrían necesitarse aquí, aunque es preferible que la configuración de servicios
# compartidos sea centralizada.
# MLFLOW_TRACKING_URI="http://aletheia_mlflow_host:5000"

# JWT Secret Key (si el módulo emite/valida sus propios tokens y no usa uno global)
# MODULE_JWT_SECRET_KEY="a_separate_secret_for_this_module"
