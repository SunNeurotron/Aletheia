# -----------------------------------------------------------------------------
# Aletheia-Omega Environment Variables Example
#
# Copy this file to .env in the aletheia_omega/ directory and customize it.
# -----------------------------------------------------------------------------

# --- PostgreSQL Database Configuration ---
# Full connection string used by SQLAlchemy (Alembic and application).
ALETHEIA_OMEGA_DATABASE_URL="postgresql://omega_user:omega_pass@localhost:5434/aletheia_omega_db"
# Note: Adjust user, password, host, port, and db_name as needed.
# Ensure the port (e.g., 5434) does not conflict with other PostgreSQL instances.

# --- JWT (JSON Web Token) Configuration ---
# Secret key for encoding/decoding JWTs.
# This might use the GLOBAL_JWT_SECRET_KEY if it's intended to integrate seamlessly
# with Aletheia_v3's authentication, or it could have its own if it's more independent.
# Option 1: Use a global secret (if tokens are shared/validated across services)
# GLOBAL_JWT_SECRET_KEY="a-global-secret-key-that-must-be-changed-for-production"
# Option 2: Use a module-specific secret
OMEGA_JWT_SECRET_KEY="your-omega-specific-secure-random-secret-key"
OMEGA_JWT_ALGORITHM="HS256"
OMEGA_ACCESS_TOKEN_EXPIRE_MINUTES=30
# If this service has its own token endpoint:
# OMEGA_OAUTH2_SCHEME_TOKEN_URL="/api/omega/v1/auth/token" # Example path

# --- API Server Configuration ---
# Host and port for the FastAPI application server (uvicorn).
OMEGA_API_HOST="0.0.0.0"
OMEGA_API_PORT="8001" # Ensure this doesn't conflict with other services.

# --- Application Environment ---
APP_ENVIRONMENT="development" # development, staging, production
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- MLflow Configuration (if Aletheia-Omega logs to MLflow) ---
# MLFLOW_TRACKING_URI="http://localhost:5000" # Or the central MLflow instance

# --- Other Service URLs (if Aletheia-Omega interacts with other Aletheia services) ---
# ALETHEIA_V3_API_URL="http://localhost:8000"

# --- Specific Aletheia-Omega Settings ---
# EXAMPLE_OMEGA_FEATURE_X_ENABLED=true
# EXAMPLE_OMEGA_PARAMETER_Y=123
```
