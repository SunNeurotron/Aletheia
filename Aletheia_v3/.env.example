# -----------------------------------------------------------------------------
# Aletheia v3 Environment Variables Example
#
# Copy this file to .env in the Aletheia_v3/ directory and customize it for
# your local development environment.
# These variables are typically used by docker-compose.yml and the application.
# -----------------------------------------------------------------------------

# --- PostgreSQL Database Configuration ---
# Used by the 'db' service in docker-compose.yml and by the application to connect.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=aletheia_db
# DB_HOST is typically 'db' when running within docker-compose network.
# For external connections, this would be 'localhost' or your DB server's address.
DB_HOST=db
DB_PORT=5432

# --- Application Database URL ---
# Full connection string used by SQLAlchemy (Alembic and application).
# If this is set, it overrides the individual POSTGRES_* variables for constructing the URL.
# Ensure this matches the user, password, host, port, and db_name above for consistency
# when running with docker-compose.
ALETHEIA_V3_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# --- Redis Configuration ---
# Used by Celery for message broker and result backend.
REDIS_HOST=redis
REDIS_PORT=6379

# --- Celery Configuration ---
# Full URLs for Celery broker and result backend.
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/0
# C_FORCE_ROOT=true # Set to "true" if Celery needs to run as root (common in Docker).

# --- MLflow Configuration ---
# URI for the MLflow tracking server.
MLFLOW_TRACKING_URI=http://mlflow:5000
# If using S3 for MLflow artifacts, uncomment and configure these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# MLFLOW_S3_ENDPOINT_URL= # For MinIO or other S3-compatible storage

# --- JWT (JSON Web Token) Configuration ---
# Secret key for encoding/decoding JWTs. KEEP THIS SECRET IN PRODUCTION.
# This should be a long, random, and unique string.
GLOBAL_JWT_SECRET_KEY=a-global-secret-key-that-must-be-changed-for-production
GLOBAL_JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Token URL for OAuth2 password flow (used by FastAPI documentation and clients)
# This should be the path to your token endpoint (e.g., /api/v1/auth/token)
OAUTH2_SCHEME_TOKEN_URL=token # Example, adjust to actual API path if prefixed

# --- API Server Configuration ---
# Host and port for the FastAPI application server (uvicorn).
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard Configuration ---
# Port for the Streamlit dashboard.
DASHBOARD_PORT=8501
# Base URL of the API service, used by the dashboard to make calls.
API_BASE_URL=http://api:${API_PORT}
# URL for accessing the MLflow UI, can be used by the dashboard to link to experiments.
MLFLOW_UI_URL=http://mlflow:5000 # Or http://localhost:5000 if accessing from host browser

# --- Application Environment ---
# Sets the environment mode (e.g., development, staging, production).
# This can be used by the application to enable/disable debug features, etc.
APP_ENVIRONMENT=development
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- CORS (Cross-Origin Resource Sharing) ---
# Example: Allow all origins (USE WITH CAUTION, especially in production)
# CORS_ORIGINS=["*"]
# Example: Allow specific origins
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8501","https://yourdomain.com"]

# --- Other Potential Configurations ---
# Any other application-specific settings.
# EXAMPLE_SETTING=example_value
```
